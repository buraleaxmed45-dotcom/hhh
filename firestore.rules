rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function isValidSharedImage(data) {
      return data.keys().hasAll(['base64', 'createdAt']) 
        && data.keys().size() <= 4
        && data.base64 is string && data.base64.size() <= 1048576 // 1MB limit check
        && data.createdAt == request.time;
    }

    match /images/{imageId} {
      allow get: if true;
      allow create: if true; // Relaxed for toolkit mode, still size checked by app
    }
  }
}
